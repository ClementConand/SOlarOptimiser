# =============================================================================
# Solar Optimizer — Environment variables
# Copy to .env and fill in the values
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-please-generate-with-openssl-rand-hex-32
DEBUG=false

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./solar_optimizer.db

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Solar constants ───────────────────────────────────────────────────────────
ELECTRICITY_PRICE_EUR_KWH=0.2276
ELECTRICITY_PRICE_INCREASE_RATE=0.04
CO2_FACTOR_KG_KWH=0.0571
SYSTEM_EFFICIENCY=0.82
PREMIUM_PRICE_EUR=29.0

# ── Production PostgreSQL (docker-compose.prod.yml) ───────────────────────────
POSTGRES_USER=solar
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=solar_optimizer
DOMAIN=yourdomain.com
